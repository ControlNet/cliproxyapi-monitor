# CLIProxyAPI management Center
# Optional when dashboard runs in Docker with mounted config.yaml.
CLIPROXY_SECRET_KEY=
# Required. Include protocol. Internal Docker HTTP is supported.
# Examples: http://cli-proxy-api:8317 (docker internal), https://your-domain.com (public HTTPS)
CLIPROXY_API_BASE_URL=

# Database
DATABASE_URL=
# Optional fallback if your platform exposes POSTGRES_URL instead of DATABASE_URL.
POSTGRES_URL=
# Optional PostgreSQL CA certificate for SSL verification.
# Supports raw PEM content or base64-encoded PEM.
DATABASE_CA=
# Optional connection pool tuning.
DATABASE_POOL_MAX=5
DATABASE_POOL_IDLE_TIMEOUT_MS=10000
DATABASE_POOL_CONNECTION_TIMEOUT_MS=5000
DATABASE_POOL_MAX_USES=7500

# Security
PASSWORD=
# Auth cookie security policy: default false/empty for internal HTTP.
# Set AUTH_COOKIE_SECURE=true when dashboard is served over HTTPS.
AUTH_COOKIE_SECURE=false
CRON_SECRET=<any-long-secret-string>

# Optional sync tuning (milliseconds / row chunk size)
NEXT_PUBLIC_SYNC_TIMEOUT_MS=60000
AUTH_FILES_INSERT_CHUNK_SIZE=500
USAGE_INSERT_CHUNK_SIZE=153
